<UserControl x:Class="QuanLyKhachHang.Views.ThayDoiQuyDinhView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F0F0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SIDEBAR ─────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="#1F3045">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="THAY ĐỔI QUY ĐỊNH"
                           Foreground="White" FontSize="13" FontWeight="Bold"
                           TextWrapping="Wrap" Margin="16,0,16,20"/>

                <!-- Nav: Loại Vắc-xin -->
                <Border x:Name="navBorderLoai" Background="#2D4D6B" Margin="0,0,0,2">
                    <Button x:Name="btnNavLoai" Click="NavLoai_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="16,12"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☰" Foreground="White" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Loại Vắc-xin" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Nav: Tham số Hệ thống -->
                <Border x:Name="navBorderThamSo" Background="Transparent" Margin="0,0,0,2">
                    <Button x:Name="btnNavThamSo" Click="NavThamSo_Click"
                            Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="16,12"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☰" Foreground="#9AB3CB" FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Tham số Hệ thống" Foreground="#9AB3CB" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── CONTENT AREA ─────────────────────────────────────────────── -->
        <Grid Grid.Column="1">

            <!-- ══ PANEL: LOẠI VẮC-XIN ══ -->
            <Grid x:Name="panelLoaiVacXin" Visibility="Visible" Margin="22,16,22,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="LOẠI VẮC-XIN"
                           FontSize="22" FontWeight="Bold" Foreground="#1F3045" Margin="0,0,0,12"/>

                <!-- Search bar -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="txtSearch"
                             Style="{StaticResource InputStyle}"
                             Tag="Tìm kiếm theo mã hoặc tên loại..."
                             TextChanged="TxtSearch_TextChanged"
                             MaxWidth="360" HorizontalAlignment="Left"/>
                </Grid>

                <!-- DataGrid -->
                <Border Grid.Row="2" Background="White" BorderBrush="#C7D3E8"
                        BorderThickness="1" CornerRadius="6" ClipToBounds="True"
                        MaxHeight="200">
                    <DataGrid x:Name="dgLoaiVacXin"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" CanUserSortColumns="False"
                              SelectionMode="Single"
                              GridLinesVisibility="All" HeadersVisibility="Column"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#F8FAFC"
                              BorderThickness="0" FontSize="13" RowHeight="36">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <!-- STT -->
                            <DataGridTemplateColumn Header="STT" Width="55">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#E9EEF6">
                                            <TextBlock Text="{Binding Stt}" FontSize="13" Foreground="#1F3045"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Mã -->
                            <DataGridTextColumn Header="Mã loại vắc-xin" Binding="{Binding MaLoaiVacXin}" Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <!-- Tên -->
                            <DataGridTextColumn Header="Tên loại vắc-xin" Binding="{Binding TenLoaiVacXin}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Pagination -->
                <StackPanel Grid.Row="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,8,0,4">
                    <Button x:Name="btnPrevPage" Content="◀  Trước"
                            Click="BtnPrevPage_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Padding="10,6" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtPageInfo" VerticalAlignment="Center"
                               FontSize="13" Foreground="#1F3045" Margin="0,0,6,0"/>
                    <Button x:Name="btnNextPage" Content="Tiếp  ▶"
                            Click="BtnNextPage_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Padding="10,6" Margin="0,0,16,0"/>
                    <TextBlock x:Name="txtPageSummary" VerticalAlignment="Center"
                               FontSize="12" Foreground="#606878"/>
                </StackPanel>

                <!-- Three action panels -->
                <Grid Grid.Row="4" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ADD -->
                    <Border Grid.Column="0" Background="White" BorderBrush="#C7D3E8"
                            BorderThickness="1" CornerRadius="6" Padding="14,12"
                            VerticalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Text="Thêm loại vắc-xin"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1F3045" Margin="0,0,0,10"/>
                            <TextBlock Text="Tên loại vắc-xin *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtTenLoaiAdd" Style="{StaticResource InputStyle}"
                                     Tag="Nhập tên loại vắc-xin" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtAddMsg" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Button Content="💾  Lưu" Click="BtnLuu_Click"
                                    Style="{StaticResource ActionButtonStyle}" Padding="14,8" Margin="0,0,0,6"/>
                            <Button Content="✕  Hủy" Click="BtnHuyAdd_Click"
                                    Style="{StaticResource ActionButtonStyle}" Padding="14,8"/>
                        </StackPanel>
                    </Border>

                    <!-- EDIT -->
                    <Border Grid.Column="2" Background="White" BorderBrush="#C7D3E8"
                            BorderThickness="1" CornerRadius="6" Padding="14,12"
                            VerticalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Text="Sửa loại vắc-xin"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1F3045" Margin="0,0,0,10"/>
                            <TextBlock Text="Tên loại vắc-xin hiện tại" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="cboSuaLoai" Style="{StaticResource ComboStyle}" Margin="0,0,0,8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TenLoaiVacXin}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="Tên loại vắc-xin mới" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtTenLoaiEdit" Style="{StaticResource InputStyle}"
                                     Tag="Nhập tên mới" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtEditMsg" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Button Content="✓  Cập nhật" Click="BtnCapNhat_Click"
                                    Style="{StaticResource ActionButtonStyle}" Padding="14,8" Margin="0,0,0,6"/>
                            <Button Content="✕  Hủy" Click="BtnHuyEdit_Click"
                                    Style="{StaticResource ActionButtonStyle}" Padding="14,8"/>
                        </StackPanel>
                    </Border>

                    <!-- DELETE -->
                    <Border Grid.Column="4" Background="White" BorderBrush="#C7D3E8"
                            BorderThickness="1" CornerRadius="6" Padding="14,12"
                            VerticalAlignment="Stretch">
                        <StackPanel>
                            <TextBlock Text="Xóa loại vắc-xin"
                                       FontSize="14" FontWeight="SemiBold" Foreground="#1F3045" Margin="0,0,0,10"/>
                            <TextBlock Text="Tên loại vắc-xin" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="cboXoaLoai" Style="{StaticResource ComboStyle}" Margin="0,0,0,8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TenLoaiVacXin}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Border Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="1"
                                    CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
                                <TextBlock Text="⚠  Chỉ có thể xóa loại vắc-xin khi không có vắc-xin thuộc loại đó."
                                           FontSize="12" Foreground="#92400E" TextWrapping="Wrap"/>
                            </Border>
                            <TextBlock x:Name="txtDeleteMsg" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Button Content="🗑  Xóa" Click="BtnXoa_Click"
                                    Style="{StaticResource ActionButtonStyle}" Padding="14,8" Margin="0,0,0,6"/>
                            <Button Content="✕  Hủy" Click="BtnHuyDel_Click"
                                    Style="{StaticResource ActionButtonStyle}" Padding="14,8"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="5" x:Name="txtLoaiError"
                           Foreground="#B91C1C" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </Grid>

            <!-- ══ PANEL: THAM SỐ HỆ THỐNG ══ -->
            <ScrollViewer x:Name="panelThamSo" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,16,22,16">
                    <TextBlock Text="THAM SỐ HỆ THỐNG"
                               FontSize="22" FontWeight="Bold" Foreground="#1F3045" Margin="0,0,0,4"/>
                    <TextBlock Text="Cập nhật các tham số quy định chung của hệ thống."
                               FontSize="13" Foreground="#606878" Margin="0,0,0,20"/>

                    <!-- QĐ1: Tuổi giám hộ -->
                    <Border Background="White" BorderBrush="#C7D3E8" BorderThickness="1"
                            CornerRadius="6" Padding="20,16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1F3045" Margin="0,0,0,8">
                                Độ tuổi bắt buộc có người giám hộ (tuổi) <Run Foreground="#B91C1C">*</Run>
                            </TextBlock>
                            <!-- Spinner -->
                            <Grid Width="130" HorizontalAlignment="Left" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="txtTuoi"
                                         Style="{StaticResource InputStyle}"
                                         VerticalContentAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <Button Content="▲" FontSize="9" Height="17"
                                            Click="BtnTuoiUp_Click"
                                            Background="#E9EEF6" BorderThickness="1"
                                            BorderBrush="#9AA5B4" Cursor="Hand"
                                            Padding="0" Margin="0,0,0,0"/>
                                    <Button Content="▼" FontSize="9" Height="17"
                                            Click="BtnTuoiDown_Click"
                                            Background="#E9EEF6" BorderThickness="1"
                                            BorderBrush="#9AA5B4" Cursor="Hand"
                                            Padding="0"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Trẻ dưới độ tuổi này khi tiêm chủng bắt buộc phải có người giám hộ đi kèm."
                                       FontSize="12" Foreground="#606878" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- QĐ3: Số ngày hạn nhập -->
                    <Border Background="White" BorderBrush="#C7D3E8" BorderThickness="1"
                            CornerRadius="6" Padding="20,16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1F3045" Margin="0,0,0,8" TextWrapping="Wrap">
                                Số ngày tối thiểu còn lại trước hết hạn tính từ ngày nhập (ngày) <Run Foreground="#B91C1C">*</Run>
                            </TextBlock>
                            <!-- Spinner -->
                            <Grid Width="130" HorizontalAlignment="Left" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="txtNgayHan"
                                         Style="{StaticResource InputStyle}"
                                         VerticalContentAlignment="Center"/>
                                <StackPanel Grid.Column="1">
                                    <Button Content="▲" FontSize="9" Height="17"
                                            Click="BtnNgayHanUp_Click"
                                            Background="#E9EEF6" BorderThickness="1"
                                            BorderBrush="#9AA5B4" Cursor="Hand"
                                            Padding="0" Margin="0,0,0,0"/>
                                    <Button Content="▼" FontSize="9" Height="17"
                                            Click="BtnNgayHanDown_Click"
                                            Background="#E9EEF6" BorderThickness="1"
                                            BorderBrush="#9AA5B4" Cursor="Hand"
                                            Padding="0"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Vắc-xin phải có số ngày còn lại trước hết hạn lớn hơn hoặc bằng giá trị này mới được phép nhập kho."
                                       FontSize="12" Foreground="#606878" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Buttons + message -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="✓  Cập nhật" Click="BtnLuuThamSo_Click"
                                Style="{StaticResource ActionButtonStyle}" Padding="16,9" Margin="0,0,8,0"/>
                        <Button Content="↺  Đặt lại" Click="BtnDatLai_Click"
                                Style="{StaticResource ActionButtonStyle}" Padding="16,9" Margin="0,0,12,0"/>
                        <TextBlock x:Name="txtThamSoMsg" VerticalAlignment="Center"
                                   FontSize="13" Foreground="#166534"/>
                    </StackPanel>

                    <TextBlock x:Name="txtThamSoError" Foreground="#B91C1C"
                               FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
