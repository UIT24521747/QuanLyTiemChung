<UserControl x:Class="QuanLyKhachHang.Views.PhieuNhapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Background="#F0F0F0">
    <Grid Margin="22,16,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Lập Phiếu Nhập Vắc-xin"
                   FontSize="28" FontWeight="Bold" Foreground="#1F3045" Margin="0,0,0,14"/>

        <!-- Header: MaPhieuNhap | NhaCungCap | NgayNhap | TongTien -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Mã phiếu nhập" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="txtMaPN" Style="{StaticResource InputStyle}" IsReadOnly="True" Background="#E9EEF6"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Nhà cung cấp *" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="txtNhaCungCap" Style="{StaticResource InputStyle}"
                         Tag="Công ty Dược phẩm Việt Đức"/>
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="Ngày nhập" Style="{StaticResource FieldLabelStyle}"/>
                <DatePicker x:Name="dpNgayNhap" Style="{StaticResource DateStyle}"/>
            </StackPanel>
            <StackPanel Grid.Column="6">
                <TextBlock Text="Tổng giá trị (VNĐ)" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="txtTongTien" Style="{StaticResource InputStyle}"
                         IsReadOnly="True" Background="#E9EEF6" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <!-- Inline editable lot grid -->
        <Border Grid.Row="2" Background="White" BorderBrush="#C7D3E8" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
            <DataGrid x:Name="dgLots"
                      AutoGenerateColumns="False"
                      CanUserAddRows="True"
                      CanUserDeleteRows="False"
                      CanUserSortColumns="False"
                      SelectionMode="Single"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC"
                      BorderThickness="0"
                      FontSize="11"
                      RowHeight="26"
                      CellEditEnding="DgLots_CellEditEnding">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </DataGrid.CellStyle>

                <DataGrid.Columns>

                    <!-- STT: Stretch cell so Border fills full row height -->
                    <DataGridTemplateColumn Header="STT" Width="32" IsReadOnly="True">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E9EEF6">
                                    <TextBlock Text="{Binding RowNum}" FontSize="11"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Mã Lô: manual input -->
                    <DataGridTemplateColumn Header="Mã Lô *" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding MaLo, TargetNullValue=''}"
                                               Padding="6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="LO..."
                                               Foreground="#B8C0CC" Padding="6,0"
                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MaLo}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MaLo}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding MaLo, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Padding="6,4" FontSize="11"
                                         VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Mã Vắc-xin: combo selector → auto-fills Tên + Loại -->
                    <DataGridTemplateColumn Header="Mã Vắc-xin *" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding MaVacXin, TargetNullValue=''}"
                                               VerticalAlignment="Center" Padding="6,0"/>
                                    <TextBlock Grid.Column="1" Text="▾" FontSize="11"
                                               Foreground="#606878"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding VacXinList, ElementName=Root}"
                                          SelectedItem="{Binding SelectedVacXin, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ComboStyle}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MaVacXin}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Tên Vắc-xin: auto-filled read-only -->
                    <DataGridTemplateColumn Header="Tên Vắc-xin" Width="90" IsReadOnly="True">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E9EEF6">
                                    <TextBlock Text="{Binding TenVacXin}" FontSize="11" Foreground="#1F3045"
                                               VerticalAlignment="Center" Padding="6,0"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Loại Vắc-xin: auto-filled read-only -->
                    <DataGridTemplateColumn Header="Loại Vắc-xin" Width="78" IsReadOnly="True">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E9EEF6">
                                    <TextBlock Text="{Binding TenLoaiVacXin}" FontSize="11" Foreground="#1F3045"
                                               VerticalAlignment="Center" Padding="6,0"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Hãng sản xuất: with placeholder -->
                    <DataGridTemplateColumn Header="Hãng sản xuất" Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding HangSanXuat, TargetNullValue=''}"
                                               Padding="6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Pfizer..."
                                               Foreground="#B8C0CC" Padding="6,0"
                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HangSanXuat}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HangSanXuat}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding HangSanXuat, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Padding="6,4" FontSize="11"
                                         VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Ngày hết hạn: calendar icon always visible to hint date picker -->
                    <DataGridTemplateColumn Header="Ngày hết hạn *" Width="88">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="tbDate" Grid.Column="0"
                                               Text="{Binding NgayHetHan, StringFormat=dd/MM/yyyy, TargetNullValue='Chọn ngày...'}"
                                               Padding="6,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="📅" FontSize="11"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#606878" IsHitTestVisible="False"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding NgayHetHan}" Value="{x:Null}">
                                        <Setter TargetName="tbDate" Property="Foreground" Value="#B8C0CC"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <DatePicker SelectedDate="{Binding NgayHetHan, UpdateSourceTrigger=PropertyChanged}"
                                            Loaded="NhapLo_DatePicker_Loaded"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Số lượng nhập: with placeholder -->
                    <DataGridTemplateColumn Header="Số lượng nhập *" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding SoLuongNhap}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Padding="6,0"/>
                                    <TextBlock Text="100"
                                               Foreground="#B8C0CC" Padding="6,0"
                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SoLuongNhap}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding SoLuongNhap, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Padding="6,4" FontSize="11"
                                         VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Đơn giá: with placeholder -->
                    <DataGridTemplateColumn Header="Đơn giá *" Width="75">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding DonGia, StringFormat=N0}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Padding="6,0"/>
                                    <TextBlock Text="200000"
                                               Foreground="#B8C0CC" Padding="6,0"
                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DonGia}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding DonGia, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Padding="6,4" FontSize="11"
                                         VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Thành Tiền: Stretch cell so Border fills full row height -->
                    <DataGridTemplateColumn Header="Thành Tiền" Width="82" IsReadOnly="True">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E9EEF6">
                                    <TextBlock Text="{Binding ThanhTien, StringFormat=N0}" FontSize="11"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               FontWeight="SemiBold" Padding="6,0"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Delete per row -->
                    <DataGridTemplateColumn Header="" Width="30">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑" FontSize="11"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#DC2626" Cursor="Hand"
                                        Click="BtnDeleteLotRow_Click" Tag="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3" x:Name="txtPnError"
                   Foreground="#B91C1C" FontSize="11"
                   TextWrapping="Wrap" Margin="0,6,0,6"/>

        <Grid Grid.Row="4" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Lập phiếu nhập"
                    Click="BtnLapPhieu_Click" Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Left" Margin="0" Padding="16,9"/>
            <Button Grid.Column="2" Content="🔍  Tra cứu Vắc-xin"
                    Click="BtnTraCuuVX_Click" Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Left" Margin="0" Padding="16,9"/>
            <Button Grid.Column="4" Content="Làm mới"
                    Click="BtnLamMoi_Click" Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Left" Margin="0" Padding="16,9"/>
            <Button Grid.Column="6" Content="→  Thoát"
                    Click="BtnThoat_Click" Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Right" Margin="0" Padding="16,9"/>
        </Grid>
    </Grid>
</UserControl>
