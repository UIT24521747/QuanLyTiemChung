<UserControl x:Class="QuanLyKhachHang.Views.VacXinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Background="#F0F0F0">
    <Grid Margin="22,16,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Lập Danh Mục Vắc-xin"
                   FontSize="28" FontWeight="Bold" Foreground="#1F3045" Margin="0,0,0,14"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#C7D3E8" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#EBF0FA" Padding="10,6">
                    <TextBlock Text="BẢNG NHẬP DÒNG VẮC-XIN MỚI"
                               FontSize="13" FontWeight="SemiBold" Foreground="#2D3F56"/>
                </Border>

                <DataGrid Grid.Row="1" x:Name="dgVacXin"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="False"
                          CanUserSortColumns="False"
                          SelectionMode="Single"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          Background="White"
                          RowBackground="White"
                          AlternatingRowBackground="#F8FAFC"
                          BorderThickness="0"
                          FontSize="13"
                          RowHeight="32">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>

                        <!-- STT: Stretch cell so Border fills full row height -->
                        <DataGridTemplateColumn Header="STT" Width="50" IsReadOnly="True">
                            <DataGridTemplateColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#E9EEF6">
                                        <TextBlock Text="{Binding RowNum}" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Tên Vắc-xin: with placeholder "Phế cầu, Thủy đậu..." -->
                        <DataGridTemplateColumn Header="Tên Vắc-xin *" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding TenVacXin, TargetNullValue=''}"
                                                   Padding="6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Phế cầu, Thủy đậu..."
                                                   Foreground="#B8C0CC" Padding="6,0"
                                                   VerticalAlignment="Center" IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TenVacXin}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TenVacXin}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding TenVacXin, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Padding="6,4" FontSize="13"
                                             VerticalContentAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- Loại Vắc-xin: display shows TenLoaiVacXin + ▾; edit shows ComboBox -->
                        <DataGridTemplateColumn Header="Loại Vắc-xin *" Width="145">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="22"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TenLoaiVacXin}"
                                                   VerticalAlignment="Center" Padding="6,0"/>
                                        <TextBlock Grid.Column="1" Text="▾" FontSize="13"
                                                   Foreground="#606878"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding LoaiVacXinList, ElementName=Root}"
                                              SelectedItem="{Binding SelectedLoaiVacXin, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="TenLoaiVacXin"
                                              Style="{StaticResource ComboStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Khoảng Cách Giữa Các Mũi (Ngày)" Width="210">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding KhoangCach}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Padding="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding KhoangCach, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Padding="6,4" FontSize="13"
                                             VerticalContentAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- Delete per row -->
                        <DataGridTemplateColumn Header="Thao tác" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑" FontSize="16"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#DC2626" Cursor="Hand"
                                            Click="BtnDeleteRow_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" x:Name="txtVxError"
                   Foreground="#B91C1C" FontSize="13"
                   TextWrapping="Wrap" Margin="0,6,0,6"/>

        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="⊕  Thêm Vắc-xin"
                    Click="BtnThem_Click" Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Left" Margin="0" Padding="16,9"/>
            <Button Grid.Column="2" Content="🔍  Tra cứu vắc-xin"
                    Click="BtnTraCuu_Click" Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Left" Margin="0" Padding="16,9"/>
            <Button Grid.Column="4" Content="→  Thoát"
                    Click="BtnThoat_Click" Style="{StaticResource ActionButtonStyle}"
                    HorizontalAlignment="Right" Margin="0" Padding="16,9"/>
        </Grid>
    </Grid>
</UserControl>
