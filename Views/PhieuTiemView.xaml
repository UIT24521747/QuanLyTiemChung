<UserControl x:Class="QuanLyKhachHang.Views.PhieuTiemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Background="#F0F0F0">
    <Grid Margin="22,16,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Lập Phiếu Đăng Ký Tiêm Phòng"
                   FontSize="28" FontWeight="Bold" Foreground="#1F3045" Margin="0,0,0,14"/>

        <!-- Row 1: Mã phiếu | Khách hàng | Ngày tiêm -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Mã phiếu Đăng Ký" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="txtMaPT" Style="{StaticResource InputStyle}"
                         IsReadOnly="True" Background="#E9EEF6"
                         Tag="Giá trị phát sinh"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Khách hàng *" Style="{StaticResource FieldLabelStyle}"/>
                <ComboBox x:Name="cboKhachHang" Style="{StaticResource ComboStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TenKH}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="Ngày tiêm" Style="{StaticResource FieldLabelStyle}"/>
                <DatePicker x:Name="dpNgayTiem" Style="{StaticResource DateStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Bác sĩ | Tổng tiền -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Bác sĩ thực hiện" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="txtBacSi" Style="{StaticResource InputStyle}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Tổng tiền (VNĐ)" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox x:Name="txtTongTien" Style="{StaticResource InputStyle}"
                         IsReadOnly="True" Background="#E9EEF6" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <!-- Row 3: Ghi chú -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox x:Name="txtGhiChu" Style="{StaticResource InputStyle}"/>
        </StackPanel>

        <!-- Row 4: Detail grid -->
        <Border Grid.Row="4" Background="White" BorderBrush="#C7D3E8" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
            <DataGrid x:Name="dgChiTiet"
                      AutoGenerateColumns="False"
                      CanUserAddRows="True"
                      CanUserDeleteRows="False"
                      CanUserSortColumns="False"
                      SelectionMode="Single"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC"
                      BorderThickness="0"
                      FontSize="13"
                      RowHeight="32"
                      CellEditEnding="DgChiTiet_CellEditEnding">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>

                    <!-- STT -->
                    <DataGridTemplateColumn Header="STT" Width="50" IsReadOnly="True">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E9EEF6">
                                    <TextBlock Text="{Binding RowNum}" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Tên Vắc-xin (readonly, auto from MaLo) -->
                    <DataGridTextColumn Header="Tên Vắc-Xin" Binding="{Binding TenVacXin}" Width="*" MinWidth="130" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                                <Setter Property="Background" Value="#F4F6FA"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Loại Vắc-xin (readonly) -->
                    <DataGridTextColumn Header="Loại Vắc-Xin" Binding="{Binding TenLoaiVacXin}" Width="100" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                                <Setter Property="Background" Value="#F4F6FA"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Hãng Sản Xuất (readonly) -->
                    <DataGridTextColumn Header="Hãng Sản Xuất" Binding="{Binding HangSanXuat}" Width="110" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                                <Setter Property="Background" Value="#F4F6FA"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Mã Lô: ComboBox -->
                    <DataGridTemplateColumn Header="Mã Lô *" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding MaLo}"
                                               VerticalAlignment="Center" Padding="6,0"/>
                                    <TextBlock Grid.Column="1" Text="▾" FontSize="13"
                                               Foreground="#606878"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding LoVacXinList, ElementName=Root}"
                                          SelectedItem="{Binding SelectedLoVacXin, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ComboStyle}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MaLo}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Số Lượng -->
                    <DataGridTemplateColumn Header="Số Lượng *" Width="85">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding SoLuong}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Padding="6,0"/>
                                    <TextBlock Text="0" Foreground="#B8C0CC"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Padding="6,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SoLuong}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Padding="6,4" FontSize="13"
                                         VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Đơn Giá (readonly, gray) -->
                    <DataGridTemplateColumn Header="Đơn Giá" Width="100" IsReadOnly="True">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E9EEF6">
                                    <TextBlock Text="{Binding DonGia, StringFormat=N0}" FontSize="13"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Padding="6,0"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Thành Tiền (readonly, gray) -->
                    <DataGridTemplateColumn Header="Thành Tiền" Width="110" IsReadOnly="True">
                        <DataGridTemplateColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGridTemplateColumn.CellStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#E9EEF6">
                                    <TextBlock Text="{Binding ThanhTien, StringFormat=N0}" FontSize="13"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               FontWeight="SemiBold" Padding="6,0"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Delete -->
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑" FontSize="13"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#DC2626" Cursor="Hand"
                                        Click="BtnDeleteRow_Click" Tag="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="5" x:Name="txtError"
                   Foreground="#B91C1C" FontSize="13"
                   TextWrapping="Wrap" Margin="0,6,0,6"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,6,0,0">
            <Button Content="Lập phiếu đăng ký"
                    Click="BtnLapPhieu_Click" Style="{StaticResource ActionButtonStyle}"
                    Padding="16,9" Margin="0,0,8,0"/>
            <Button Content="Làm mới"
                    Click="BtnLamMoi_Click" Style="{StaticResource ActionButtonStyle}"
                    Padding="16,9" Margin="0,0,8,0"/>
            <Button Content="→  Thoát"
                    Click="BtnThoat_Click" Style="{StaticResource ActionButtonStyle}"
                    Padding="16,9" Margin="0"/>
        </StackPanel>
    </Grid>
</UserControl>
