<Window x:Class="QuanLyKhachHang.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:QuanLyKhachHang.Views"
        Title="Hệ Thống Quản Lý Tiêm Chủng"
        FontFamily="{StaticResource AppFont}"
        Width="860"
        Height="900"
        MinWidth="760"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#DDE4EE">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D3F56">
            <TextBlock Text="HỆ THỐNG QUẢN LÝ TIÊM CHỦNG"
                       Margin="24,0,0,0"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1" Margin="10,10,10,10" Background="#F0F0F0">
            <TabItem Header="Khách Hàng">
                <views:KhachHangView/>
            </TabItem>
            <TabItem Header="Danh Mục Vắc-xin">
                <views:VacXinView/>
            </TabItem>
            <TabItem Header="Phiếu Nhập Vắc-xin">
                <views:PhieuNhapView/>
            </TabItem>
            <TabItem Header="Tra Cứu Vắc-xin">
                <views:TraCuuVacXinView/>
            </TabItem>
            <TabItem Header="Đăng Ký Tiêm Phòng">
                <views:PhieuTiemView/>
            </TabItem>
            <TabItem Header="Báo Cáo">
                <views:BaoCaoView/>
            </TabItem>
            <TabItem Header="Thay Đổi Quy Định">
                <views:ThayDoiQuyDinhView/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
