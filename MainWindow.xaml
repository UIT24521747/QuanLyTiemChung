<Window x:Class="QuanLyKhachHang.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Quản Lý Khách Hàng" Height="900" Width="800"
        Background="#F5F5F5" WindowStartupLocation="CenterScreen">
        
    <Grid>
        <StackPanel Background="#2C3E50" Orientation="Vertical" Height="60" VerticalAlignment="Top">
            <TextBlock Text="HỆ THỐNG QUẢN LÝ KHÁCH HÀNG"
                       Foreground="White" FontSize="24" FontWeight="Bold"
                       Margin="20,15,0,0"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,60,0,0">
            <StackPanel Margin="30,20,30,20">
                <Border BorderBrush="#2C3E50" BorderThickness="2" Padding="20,15,20,15" Background="White">
                    <StackPanel>
                        <TextBlock Text="PHIẾU ĐĂNG KÝ THÔNG TIN KHÁCH HÀNG" FontSize="14" FontWeight="Bold"
                                   Foreground="#2C3E50" Margin="0,0,0,15"/>

                        <TextBlock x:Name="txtInfoAge" Text="Nếu khách hàng dưới 18 tuổi có dấu * thì bắt buộc phải nhập thông tin người giám hộ"
                                   FontSize="11" Foreground="#E74C3C" Background="#FCE4EC" Padding="10,5,10,5"
                                   TextWrapping="Wrap" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,15">
                                <TextBlock Text="Mã khách hàng *" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtMaKH" IsReadOnly="True" Background="#F0F0F0" VerticalContentAlignment="Center"
                                         Padding="10,5,10,5" FontSize="12" MinHeight="34" BorderThickness="1" BorderBrush="#CCCCCC"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                                <TextBlock Text="Họ tên *" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtTenKH" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,15">
                                <TextBlock Text="Giới tính" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtGioiTinh" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                                <TextBlock Text="Số điện thoại *" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtSDT" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,15">
                                <TextBlock Text="Địa chỉ *" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtDiaChi" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,15">
                                <TextBlock Text="Ngày sinh *" FontWeight="Bold" Margin="0,0,0,5"/>
                                <DatePicker x:Name="dpNgaySinh" MinHeight="34" MinWidth="170"
                                            BorderThickness="1" BorderBrush="#CCCCCC"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="CCCD *" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtCCCD" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,0">
                                <TextBlock Text="Email" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtEmail" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#2C3E50" BorderThickness="2" Padding="20,15,20,15" Background="White" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="THÔNG TIN NGƯỜI GIÁM HỘ" FontSize="14" FontWeight="Bold"
                                   Foreground="#2C3E50" Margin="0,0,0,15"/>

                        <TextBlock Text="Bắt buộc với người dưới 18 tuổi (18 tuổi có thể bỏ qua thông tin này)"
                                   FontSize="11" Foreground="#555555" Background="#F5F5F5" Padding="10,5,10,5"
                                   TextWrapping="Wrap" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,15">
                                <TextBlock Text="Mã người giám hộ" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtMaGH" IsReadOnly="True" Background="#F0F0F0"
                                         Padding="10,5,10,5" FontSize="12" MinHeight="34" BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                                <TextBlock Text="Họ tên người giám hộ" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtTenGH" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,15">
                                <TextBlock Text="SĐT" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtSDT_GH" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                                <TextBlock Text="Email" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtEmail_GH" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,15">
                                <TextBlock Text="Giới tính" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtGioiTinh_GH" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,15">
                                <TextBlock Text="Ngày sinh" FontWeight="Bold" Margin="0,0,0,5"/>
                                <DatePicker x:Name="dpNgaySinh_GH" MinHeight="34" MinWidth="170"
                                            BorderThickness="1" BorderBrush="#CCCCCC"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="CCCD" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtCCCD_GH" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,0">
                                <TextBlock Text="Địa chỉ" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtDiaChi_GH" Padding="10,5,10,5" FontSize="12" MinHeight="34"
                                         BorderThickness="1" BorderBrush="#CCCCCC" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="txtError" Foreground="Red" FontSize="12" TextWrapping="Wrap"
                           Margin="0,15,0,0" Padding="10,5,10,5" Background="#FFEBEE"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20">
                    <Button x:Name="btn1" Content="Tiếp nhận" Click="Btn1_Click"
                            Background="#0B5ED7" Foreground="White" Padding="12,8" FontSize="12"
                            FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0" MinWidth="100"/>
                    <Button x:Name="btn2" Content="Khách hàng mới" Click="Btn2_Click"
                            Background="#0B5ED7" Foreground="White" Padding="12,8" FontSize="12"
                            FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0" MinWidth="130"/>
                    <Button x:Name="btn3" Content="Tìm" Click="Btn3_Click"
                            Background="#0B5ED7" Foreground="White" Padding="12,8" FontSize="12"
                            FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0" MinWidth="80"/>
                    <Button x:Name="btn4" Content="Xóa" Click="Btn4_Click"
                            Background="#0B5ED7" Foreground="White" Padding="12,8" FontSize="12"
                            FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0" MinWidth="80"/>
                    <Button x:Name="btn5" Content="Cập nhật" Click="Btn5_Click"
                            Background="#0B5ED7" Foreground="White" Padding="12,8" FontSize="12"
                            FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0" MinWidth="100"/>
                    <Button x:Name="btn6" Content="Thoát" Click="Btn6_Click"
                            Background="#0B5ED7" Foreground="White" Padding="12,8" FontSize="12"
                            FontWeight="Bold" Cursor="Hand" MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
