<Window x:Class="QuanLyKhachHang.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hệ Thống Quản Lý Khách Hàng" Height="900" Width="980"
        Background="#E2E8F0" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50">
            <TextBlock Text="HỆ THỐNG QUẢN LÝ KHÁCH HÀNG"
                       Foreground="White" FontSize="37" FontWeight="Bold"
                       Margin="20,14,0,0"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="#F8FAFC" Margin="36,14,36,14" Padding="24,16,24,16">
                <StackPanel>
                    <TextBlock Text="Phiếu đăng ký thông tin khách hàng"
                               FontSize="41" FontWeight="Bold" Foreground="#1E293B"
                               Margin="0,0,0,18"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,14">
                            <TextBlock Text="Mã khách hàng *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtMaKH" IsReadOnly="True" Background="#F1F5F9" VerticalContentAlignment="Center"
                                     Padding="8,4,8,4" MinHeight="32" BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,14">
                            <TextBlock Text="Họ tên *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtTenKH" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,14">
                            <TextBlock Text="SĐT *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtSDT" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,14">
                            <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtEmail" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,14">
                            <TextBlock Text="Giới tính *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtGioiTinh" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,16,14">
                            <TextBlock Text="Ngày sinh *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpNgaySinh" MinHeight="32" BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="CCCD *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtCCCD" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
                            <TextBlock Text="Địa chỉ *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtDiaChi" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Thông tin người giám hộ"
                               FontSize="38" FontWeight="Bold" Foreground="#1E293B"
                               Margin="0,2,0,10"/>

                    <Border Background="#F2F4FC" Padding="10,6,10,6" Margin="0,0,0,14">
                        <TextBlock Text="ⓘ Bắt buộc với người dưới 18 tuổi (trên 18 tuổi có thể bỏ qua)."
                                   Foreground="#64748B" FontSize="11"/>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,14">
                            <TextBlock Text="Mã người giám hộ" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtMaGH" IsReadOnly="True" Background="#F1F5F9" VerticalContentAlignment="Center"
                                     Padding="8,4,8,4" MinHeight="32" BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,14">
                            <TextBlock Text="Họ tên người giám hộ" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtTenGH" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,14">
                            <TextBlock Text="SĐT" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtSDT_GH" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,14">
                            <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtEmail_GH" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,14">
                            <TextBlock Text="Giới tính" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtGioiTinh_GH" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,16,14">
                            <TextBlock Text="Ngày sinh" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpNgaySinh_GH" MinHeight="32" BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,14">
                            <TextBlock Text="CCCD" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtCCCD_GH" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,14">
                            <TextBlock Text="Địa chỉ" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtDiaChi_GH" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
                            <TextBlock Text="Quan hệ với khách hàng" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtQuanHe_GH" Padding="8,4,8,4" MinHeight="32" VerticalContentAlignment="Center"
                                     BorderThickness="1" BorderBrush="#9CA3AF"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="txtError" Foreground="#D32F2F" FontSize="12" TextWrapping="Wrap"
                               Margin="0,14,0,0" Padding="10,6,10,6" Background="#FFECEF"/>

                    <WrapPanel HorizontalAlignment="Left" Margin="0,14,0,0">
                        <Button x:Name="btn1" Content="Tiếp nhận khách hàng" Click="Btn1_Click"
                                Background="#3B82F6" Foreground="White" Padding="14,8" FontSize="12"
                                Cursor="Hand" Margin="0,0,8,8" MinWidth="145" BorderThickness="0"/>
                        <Button x:Name="btn2" Content="Khách hàng mới" Click="Btn2_Click"
                                Background="#3B82F6" Foreground="White" Padding="14,8" FontSize="12"
                                Cursor="Hand" Margin="0,0,8,8" MinWidth="120" BorderThickness="0"/>
                        <Button x:Name="btn3" Content="Tìm khách hàng" Click="Btn3_Click"
                                Background="#3B82F6" Foreground="White" Padding="14,8" FontSize="12"
                                Cursor="Hand" Margin="0,0,8,8" MinWidth="120" BorderThickness="0"/>
                        <Button x:Name="btn4" Content="Xóa khách hàng" Click="Btn4_Click"
                                Background="#3B82F6" Foreground="White" Padding="14,8" FontSize="12"
                                Cursor="Hand" Margin="0,0,8,8" MinWidth="120" BorderThickness="0"/>
                        <Button x:Name="btn5" Content="Cập nhật khách hàng" Click="Btn5_Click"
                                Background="#3B82F6" Foreground="White" Padding="14,8" FontSize="12"
                                Cursor="Hand" Margin="0,0,8,8" MinWidth="145" BorderThickness="0"/>
                        <Button x:Name="btn6" Content="Thoát" Click="Btn6_Click"
                                Background="#3B82F6" Foreground="White" Padding="14,8" FontSize="12"
                                Cursor="Hand" Margin="0,0,8,8" MinWidth="70" BorderThickness="0"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
